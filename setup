#!/bin/bash

# Define test configurations
declare -a models=("FC_196_3")
declare -a loss_types=("huber")
declare -a batch_sizes=(16)
declare -a tbatches=(1)

# Shared config
model="Prod"
norm="log1p_standard"
num_workers=16
num_epochs=80
learning_rate=0.001
beta=0.2
beta_delta=1.0
train_data_files="/leonardo_work/EUHPC_D17_070/Data_LSM_1995-2000_Large/"
test_data_files="/leonardo_work/EUHPC_D17_070/Data_LSM_1995-2000_Large/"
train_year="1996-1998"
test_year="1999"

lr_str=${learning_rate//./d}
beta_str=${beta//./d}
bd_str=${beta_delta//./d}

# Loop over all combinations
for model_name in "${models[@]}"; do
  for loss_type in "${loss_types[@]}"; do
    for batch_size in "${batch_sizes[@]}"; do
      for time_batch in "${tbatches[@]}"; do

        DATE=$(date +"%Y%m%d")
        TODAY=$(date +"%Y%m%d_%H%M%S")
        if [[ "$loss_type" == "huber" || "$loss_type" == "smoothl1" ]]; then
          bd_tag="_BetaDelta_${bd_str}"
        else
          bd_tag=""
        fi
        tag="${model_name}_nrm_${norm}_l_${loss_type}${bd_tag}_sb_${batch_size}_tb_${time_batch}_nw_${num_workers}_ne_${num_epochs}_lr_${lr_str}_beta_${beta_str}"
        run_script="run_script_lsm_${tag}.sh"
        sbatch_script="sbatch_script_${tag}.sh"
        main_folder="${model}__${model_name}_sb_${batch_size}_tb_${time_batch}_nw_${num_workers}_ne_${num_epochs}"
        sub_folder="nrm_${norm}_lr_${lr_str}_beta_${beta_str}_l_${loss_type}${bd_tag}_date_${TODAY}"
        prefix="$sub_folder"

        # Write run script
        cat <<EOF > $run_script
#!/bin/bash
echo "Time = $TODAY"
echo "Running training with model: $model_name, loss: $loss_type"

python src/main_lsm.py \\
    --root_dir "./" \\
    --main_folder "$main_folder" \\
    --sub_folder "$sub_folder" \\
    --train_data_files "$train_data_files" \\
    --test_data_files "$test_data_files" \\
    --train_year "$train_year" \\
    --test_year "$test_year" \\
    --prefix "$prefix" \\
    --dataset_type "LSM" \\
    --loss_type "$loss_type" \\
    --beta_delta "$beta_delta" \\
    --learning_rate "$learning_rate" \\
    --beta "$beta" \\
    --batch_size "$batch_size" \\
    --tbatch "$time_batch" \\
    --model_name "$model_name" \\
    --num_workers "$num_workers" \\
    --num_epochs "$num_epochs" \\
    --save_mode "True" \\
    --save_checkpoint_name "model" \\
    --save_per_samples 10000 \\
    --load_model "False"
EOF

        chmod +x $run_script

        # Write SLURM batch script
        cat <<EOF > $sbatch_script
#!/bin/bash
#SBATCH -A EUHPC_D17_070
#SBATCH -p boost_usr_prod
EOF
        # Insert QOS line if Debug
        if [ "$model" == "Debug" ]; then
          echo "#SBATCH --qos=boost_qos_dbg" >> $sbatch_script
          time_limit="00:30:00"
        else
          time_limit="16:00:00"
        fi

        # Append the rest of the SLURM script
        cat <<EOF >> $sbatch_script
#SBATCH --time=${time_limit}
#SBATCH -N 1
#SBATCH --ntasks-per-node=32
#SBATCH --gpus-per-node=4
#SBATCH --mem-per-gpu=64G
#SBATCH --job-name=lsm_${tag}
#SBATCH --error=lsm_training_${tag}_%j.err
#SBATCH --output=lsm_training_${tag}_%j.out

module load profile/deeplrn
module load cineca-ai
source /leonardo/home/userexternal/kardaneh/RTnn/python-venv/bin/activate

./$run_script
EOF
        chmod +x $sbatch_script

        echo "Generated: $run_script and $sbatch_script"
        # Optionally auto-submit
        # sbatch $sbatch_script

      done
    done
  done
done
