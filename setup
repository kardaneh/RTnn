#!/usr/bin/env bash

# ======================
# 1. Basic
# ======================
MODE="Debug"  # 'Prod' or 'Debug'
TODAY=$(date +"%Y%m%d_%H%M%S")

# ======================
# 2. Model Configuration
# ======================
type="lstm"
hidden_size=64
num_layers=2
output_channel=4
seq_length=10
feature_channel=6
embed_size=64
nhead=4
forward_expansion=4
dropout=0.0

# ======================
# 3. Training Configuration
# ======================
batch_size=16
time_batch=1
num_epochs=2
learning_rate=0.0001
loss_type="huber"
beta=0.2
beta_delta=1.0
num_workers=16

# ======================
# 4. Data Configuration
# ======================
train_data_files="/leonardo_work/EUHPC_D17_070/Data_LSM_1995-2000_Large/"
test_data_files="/leonardo_work/EUHPC_D17_070/Data_LSM_1995-2000_Large/"
train_years="1998"
test_year="1999"
norm="log1p_standard"

# ======================
# 5. Output Configuration
# ======================
save_model="True"
save_checkpoint_name="model"
save_per_samples=10000
load_model="False"

# ======================
# Generate tags
# ======================
lr_str="${learning_rate//./d}"
beta_str="${beta//./d}"

model_parts=("$type" "h${hidden_size}" "l${num_layers}")
model_name=$(IFS=_ ; echo "${model_parts[*]}")
tag="${model_name}_nrm_${norm}_l_${loss_type}_sb_${batch_size}_ne_${num_epochs}"
main_folder="${MODE}__${model_name}_sb_${batch_size}_ne_${num_epochs}"
sub_folder="nrm_${norm}_lr_${lr_str}_beta_${beta_str}_date_${TODAY}"
prefix="$sub_folder"

sbatch_script="sbatch_rtnn_${tag}.sh"

# ======================
# Create SBATCH script
# ======================
cat > $sbatch_script <<EOF
#!/usr/bin/env bash
#SBATCH -A EUHPC_D27_095
#SBATCH -p boost_usr_prod
EOF

[ "$MODE" == "Debug" ] && echo "#SBATCH --qos=boost_qos_dbg" >> $sbatch_script

cat >> $sbatch_script <<EOF
#SBATCH --time=$([ "$MODE" == "Debug" ] && echo "00:30:00" || echo "24:00:00")
#SBATCH -N 1
#SBATCH --ntasks-per-node=32
#SBATCH --gpus-per-node=4
#SBATCH --mem-per-gpu=64G
#SBATCH --job-name=rtnn_${tag}
#SBATCH --error=rtnn_${tag}_%j.err
#SBATCH --output=rtnn_${tag}_%j.out

# Load system modules (these provide PyTorch, CUDA, etc.)
module load profile/deeplrn
module load cineca-ai

# Activate virtual environment (only for pure Python packages)
source .venv/bin/activate

# Print environment info
echo "=== Environment Info ==="
echo "PyTorch version: \$(python -c 'import torch; print(torch.__version__)')"
echo "CUDA available: \$(python -c 'import torch; print(torch.cuda.is_available())')"
echo "CUDA version: \$(python -c 'import torch; print(torch.version.cuda)')"
echo "GPU count: \$(python -c 'import torch; print(torch.cuda.device_count())')"
echo ""

echo "=== RTnn Training ==="
echo "Version: \$(python -c 'import rtnn; print(rtnn.__version__)')"
echo "Model: $model_name"
echo "Start time: \$(date)"

# Run training
rtnn \\
    --root_dir "./" \\
    --main_folder "$main_folder" \\
    --sub_folder "$sub_folder" \\
    --prefix "$prefix" \\
    --type "$type" \\
    --hidden_size "$hidden_size" \\
    --num_layers "$num_layers" \\
    --output_channel "$output_channel" \\
    --seq_length "$seq_length" \\
    --feature_channel "$feature_channel" \\
    --embed_size "$embed_size" \\
    --nhead "$nhead" \\
    --forward_expansion "$forward_expansion" \\
    --dropout "$dropout" \\
    --model_name "$model_name" \\
    --batch_size "$batch_size" \\
    --tbatch "$time_batch" \\
    --num_epochs "$num_epochs" \\
    --learning_rate "$learning_rate" \\
    --loss_type "$loss_type" \\
    --beta "$beta" \\
    --beta_delta "$beta_delta" \\
    --train_data_files "$train_data_files" \\
    --test_data_files "$test_data_files" \\
    --train_years "$train_years" \\
    --test_year "$test_year" \\
    --norm "$norm" \\
    --num_workers "$num_workers" \\
    --save_model "$save_model" \\
    --save_checkpoint_name "$save_checkpoint_name" \\
    --save_per_samples "$save_per_samples" \\
    --load_model "$load_model"

echo "End time: \$(date)"
EOF

chmod +x $sbatch_script

echo "Created: $sbatch_script"
echo "Run with: sbatch $sbatch_script"
