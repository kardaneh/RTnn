#!/usr/bin/env bash

# ======================
# 0. Machine + Runtime
# ======================
Machine="HAL"   # options: LEONARDO, HAL
debug="False"         # True or False

DATA_PATH="/data/kardaneh/RTDataBase/Data_LSM_1990-2000_Large/Data_LSM_1995-2000_Large" # Path to the dataset on HAL. Adjust if needed.

# ======================
# 1. Model Configuration
# ======================
type="lstm"
hidden_size=96
num_layers=3
output_channel=4
seq_length=10
feature_channel=6
embed_size=64
nhead=4
forward_expansion=4
dropout=0.0

# ======================
# 2. Training Configuration
# ======================
batch_size=4
num_epochs=2
learning_rate=0.0001
loss_type="huber"
beta=0.2
beta_delta=1.0
num_workers=4
run_type="train"
seed=42

# ======================
# 3. Data Configuration
# ======================
train_data_files=$DATA_PATH
test_data_files=$DATA_PATH
train_years="1999"
test_year="2000"
norm="log1p_standard"
dataset_type="LSM"

# ======================
# 4. Output Configuration
# ======================
save_model="True"
save_checkpoint_name="model"
save_per_samples=10000
load_checkpoint_name="model.pth.tar"

# ======================
# 5. Tags
# ======================
lr_str="${learning_rate//./d}"
beta_str="${beta//./d}"

model_parts=("$type" "h${hidden_size}" "l${num_layers}")
model_name=$(IFS=_ ; echo "${model_parts[*]}")

tag="${model_name}_nrm_${norm}_l_${loss_type}_sb_${batch_size}_ne_${num_epochs}"

main_folder=$([ "$debug" == "True" ] && echo "Debug" || echo "Prod")"__${model_name}_sb_${batch_size}_ne_${num_epochs}"

sub_folder="nrm_${norm}_lr_${lr_str}_beta_${beta_str}"
prefix="$sub_folder"

# ======================
# Generate SBATCH Script Only (removed run script)
# ======================
PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
JOB_DIR="$PROJECT_ROOT/slurm/${main_folder}/${sub_folder}"
SLURM_IO_DIR="$PROJECT_ROOT/slurm_io/${main_folder}/${sub_folder}"
mkdir -p "$JOB_DIR"
mkdir -p "$SLURM_IO_DIR"
sbatch_script="$JOB_DIR/sbatch_rtnn_${tag}.sh"

# Create slurm_io directory if it doesn't exist


# ======================
# 6. Create SBATCH file
# ======================

cat > $sbatch_script <<EOF
#!/bin/bash
# SBATCH always at the beginning of the script!
#SBATCH --job-name=rtnn_${main_folder}_${sub_folder}_${tag}
#SBATCH --error=$SLURM_IO_DIR/rtnn_${tag}.err
#SBATCH --output=$SLURM_IO_DIR/rtnn_${tag}.out
#SBATCH --chdir=$(pwd)
EOF

# ======================
# 7. Machine-specific SBATCH config
# ======================

if [ "$Machine" == "LEONARDO" ]; then

cat >> $sbatch_script <<EOF
#SBATCH -A EUHPC_D27_095
#SBATCH -p boost_usr_prod
#SBATCH --time=$([ "$debug" == "True" ] && echo "00:30:00" || echo "24:00:00")
#SBATCH -N 1
#SBATCH --ntasks-per-node=32
#SBATCH --gpus-per-node=2
#SBATCH --mem-per-gpu=64G
EOF

[ "$debug" == "True" ] && echo "#SBATCH --qos=boost_qos_dbg" >> $sbatch_script

elif [ "$Machine" == "HAL" ]; then

cat >> $sbatch_script <<EOF
#SBATCH --partition=batch
#SBATCH --gpus=1
#SBATCH --ntasks-per-node=4
#SBATCH --mem=48G
#SBATCH --time=1:00:00
#SBATCH --nodelist=hal10
EOF

fi

# ======================
# 8. Environment setup
# ======================

if [ "$Machine" == "LEONARDO" ]; then

cat >> $sbatch_script <<EOF

module load profile/deeplrn
module load cineca-ai
source .venv/bin/activate
EOF

elif [ "$Machine" == "HAL" ]; then

cat >> $sbatch_script <<EOF

source "$PROJECT_ROOT/.venv/bin/activate"
ulimit -s unlimited
EOF

fi

# ======================
# 9. Runtime diagnostics + training
# ======================

cat >> $sbatch_script <<EOF

echo "=== Environment Info ==="
echo "PyTorch version: \$(python -c 'import torch; print(torch.__version__)')"
echo "CUDA available: \$(python -c 'import torch; print(torch.cuda.is_available())')"
echo "CUDA version: \$(python -c 'import torch; print(torch.version.cuda)')"
echo "GPU count: \$(python -c 'import torch; print(torch.cuda.device_count())')"

echo "=== RTnn Training ==="
echo "Version: \$(python -c 'import rtnn; print(rtnn.__version__)')"
echo "Model: $model_name"
echo "Run type: $run_type"
echo "Debug: $debug"
echo "Start time: \$(date)"

rtnn \\
    --root_dir "./" \\
    --main_folder "$main_folder" \\
    --sub_folder "$sub_folder" \\
    --prefix "$prefix" \\
    --dataset_type "$dataset_type" \\
    --type "$type" \\
    --hidden_size "$hidden_size" \\
    --num_layers "$num_layers" \\
    --output_channel "$output_channel" \\
    --seq_length "$seq_length" \\
    --feature_channel "$feature_channel" \\
    --embed_size "$embed_size" \\
    --nhead "$nhead" \\
    --forward_expansion "$forward_expansion" \\
    --dropout "$dropout" \\
    --model_name "$model_name" \\
    --batch_size "$batch_size" \\
    --num_epochs "$num_epochs" \\
    --learning_rate "$learning_rate" \\
    --loss_type "$loss_type" \\
    --beta "$beta" \\
    --beta_delta "$beta_delta" \\
    --train_data_files "$train_data_files" \\
    --test_data_files "$test_data_files" \\
    --train_years "$train_years" \\
    --test_year "$test_year" \\
    --norm "$norm" \\
    --num_workers "$num_workers" \\
    --save_model "$save_model" \\
    --save_checkpoint_name "$save_checkpoint_name" \\
    --save_per_samples "$save_per_samples" \\
    --load_checkpoint_name "$load_checkpoint_name" \\
    --run_type "$run_type" \\
    --seed "$seed" \\
    --debug "$debug"

echo "End time: \$(date)"
EOF

chmod +x $sbatch_script

echo "Created: $sbatch_script"
echo "Run with: sbatch $sbatch_script"
